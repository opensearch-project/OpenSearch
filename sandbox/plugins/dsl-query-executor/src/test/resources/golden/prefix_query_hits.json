  "mockResultRows": [
    ["laptop", 999],
    ["laptop_pro", 1499]
  ],
  "expectedOutputDsl": {
    "num_reduce_phases": 0,
    "hits": {
      "total": {
        "value": 0,
        "relation": "eq"
      },
      "max_score": 0.0,
      "hits": []
    }
  }
}
