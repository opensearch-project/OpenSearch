{
  "testName": "prefix_query_hits",
  "indexName": "test-index",
  "indexMapping": {
    "name": "VARCHAR",
    "price": "INTEGER"
  },
  "planType": "HITS",
  "inputDsl": {
    "query": {
      "prefix": {
        "name": {
          "value": "lap"
        }
      }
