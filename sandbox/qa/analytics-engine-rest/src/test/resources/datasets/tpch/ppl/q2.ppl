source = part | join ON p_partkey = ps_partkey partsupp | join ON s_suppkey = ps_suppkey supplier | join ON s_nationkey = n_nationkey nation | join ON n_regionkey = r_regionkey region | where p_size = 15 AND like(p_type, '%BRASS', true) AND r_name = 'EUROPE' AND ps_supplycost = [ source = partsupp | join ON s_suppkey = ps_suppkey supplier | join ON s_nationkey = n_nationkey nation | join ON n_regionkey = r_regionkey region | where r_name = 'EUROPE' and ps_partkey = p_partkey | stats min(ps_supplycost) ] | sort - s_acctbal, n_name, s_name, p_partkey | fields s_acctbal, s_name, n_name, p_partkey, p_mfgr, s_address, s_phone, s_comment | head 100
