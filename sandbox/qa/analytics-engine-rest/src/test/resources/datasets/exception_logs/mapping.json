{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0
  },
  "mappings": {
    "properties": {
      "@timestamp": {
        "type": "date"
      },
      "exception.exception_message": {
        "type": "text",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "exception.stacktrace": {
        "type": "text",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "level": {
        "type": "keyword"
      },
      "application_id": {
        "type": "long"
      },
      "service_name": {
        "type": "keyword"
      }
    }
  }
}