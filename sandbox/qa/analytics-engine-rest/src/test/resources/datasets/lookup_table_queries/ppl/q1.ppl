source=app_logs_splunk | where message like '%successfully processed%' | grok message 'request %{NUMBER:request_id}' | stats count() as total_requests, distinct_count(host) as unique_hosts, min(request_id) as min_req, max(request_id) as max_req by span(timestamp, 5m) as time_bucket, host | eval success_rate = round(total_requests * 100.0 / (total_requests + 1), 2) | where total_requests > 2 | sort - total_requests | head 15