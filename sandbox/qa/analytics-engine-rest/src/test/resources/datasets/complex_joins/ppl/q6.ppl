source=monitor_tracking | where monitor_fail=false | stats count() as successful_monitors by monitor_id | inner join left=l right=r on l.monitor_id = r.application_id [ source=app_monitor | where log_level="ERROR" | stats count() as error_monitors by application_id ] | eval reliability_score = round(successful_monitors * 100.0 / (successful_monitors + error_monitors), 2) | where reliability_score < 90 | sort reliability_score