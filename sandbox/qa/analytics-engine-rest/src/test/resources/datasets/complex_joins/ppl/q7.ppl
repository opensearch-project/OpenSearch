source=security_logs | where action in ("blocked", "denied") | stats count() as blocked_count, dc(user) as unique_users by source_ip | inner join left=l right=r on l.source_ip = r.source_ip [ source=security_logs | where result="Success" | stats count() as success_count by source_ip ] | eval threat_level = case(blocked_count > 50, 'CRITICAL', blocked_count > 20, 'HIGH', blocked_count > 0, 'MEDIUM') | where blocked_count > success_count | sort - blocked_count