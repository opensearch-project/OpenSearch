source=tax_withholding | where log_level!="ERROR" | dedup part_mid | stats count() as unique_users by realm | left join left=l right=r on l.realm = r.realm [ source=monitor_tracking | where mock_update=false | stats count() as monitor_calls by realm ] | eval user_to_monitor_ratio = round(unique_users * 1.0 / monitor_calls, 2) | where user_to_monitor_ratio > 0 | sort - unique_users
