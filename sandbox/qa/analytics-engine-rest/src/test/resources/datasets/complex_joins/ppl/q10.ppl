source=voice_verification | where verify_status="verified" | stats count() as verified_count, avg(net_audio) as avg_quality by app_id | inner join left=l right=r on l.app_id = r.app_id [ source=voice_verification | where verify_status="failed" | stats count() as failed_count by app_id ] | eval success_rate = round(verified_count * 100.0 / (verified_count + failed_count), 2) | where success_rate < 80 | sort success_rate