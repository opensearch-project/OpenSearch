source=event_processor | where processor_type="processor_success" | stats sum(filter_in_count) as total_processed by cluster_name | inner join left=l right=r on l.cluster_name = r.`cluster.name` [ source=kubernetes_logs | stats count() as log_volume by `cluster.name` ] | eval processing_efficiency = round(total_processed * 1.0 / log_volume, 2) | where processing_efficiency > 0 | sort - processing_efficiency