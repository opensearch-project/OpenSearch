{
  "from": 0,
  "size": 0,
  "timeout": "1m",
  "query": {
    "bool": {
      "must": [
        {
          "exists": {
            "field": "AdvEngineID",
            "boost": 1.0
          }
        }
      ],
      "must_not": [
        {
          "term": {
            "AdvEngineID": {
              "value": 0,
              "boost": 1.0
            }
          }
        }
      ],
      "adjust_pure_negative": true,
      "boost": 1.0
    }
  },
  "aggregations": {
    "AdvEngineID": {
      "terms": {
        "field": "AdvEngineID",
        "size": 10000,
        "min_doc_count": 1,
        "shard_min_doc_count": 0,
        "show_term_doc_count_error": false,
        "order": [
          {
            "_count": "desc"
          },
          {
            "_key": "asc"
          }
        ]
      }
    }
  }
}
