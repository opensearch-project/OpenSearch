source=app_logs | where message like '%ServiceLoggingFilter%' or service_name is not null | stats sum(case(status=200, 1 else 0)) as success, sum(case(status!=200, 1 else 0)) as failure by service_name | eval total = success + failure | where total > 5 | eval success_rate = round(success * 100.0 / total, 2) | fields service_name, success, failure, total, success_rate | sort - failure
