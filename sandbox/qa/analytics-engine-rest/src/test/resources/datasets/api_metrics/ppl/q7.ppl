source=api_metrics | stats count() as total, sum(case(status=200, 1 else 0)) as ok, sum(case(status>=400 and status<500, 1 else 0)) as four_x, sum(case(status>=500, 1 else 0)) as five_x by endpoint | eval success_rate = round(ok * 100.0 / total, 2) | eval error_4xx_rate = round(four_x * 100.0 / total, 2) | eval error_5xx_rate = round(five_x * 100.0 / total, 2) | fields endpoint, total, success_rate, error_4xx_rate, error_5xx_rate
