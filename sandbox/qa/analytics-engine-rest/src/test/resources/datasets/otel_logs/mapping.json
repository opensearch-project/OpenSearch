{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0
  },
  "mappings": {
    "properties": {
      "body": {
        "type": "text",
        "fields": {"keyword": {"type": "keyword", "ignore_above": 256}}
      },
      "droppedAttributesCount": {"type": "long"},
      "flags": {"type": "long"},
      "instrumentationScope": {
        "properties": {
          "name": {"type": "text", "fields": {"keyword": {"type": "keyword", "ignore_above": 256}}},
          "version": {"type": "text", "fields": {"keyword": {"type": "keyword", "ignore_above": 256}}}
        }
      },
      "log": {
        "properties": {
          "code": {
            "properties": {
              "filepath": {"type": "text", "fields": {"keyword": {"type": "keyword", "ignore_above": 256}}},
              "function": {"type": "text", "fields": {"keyword": {"type": "keyword", "ignore_above": 256}}},
              "lineno": {"type": "long"}
            }
          },
          "db": {
            "properties": {
              "statement": {"type": "text", "fields": {"keyword": {"type": "keyword", "ignore_above": 256}}},
              "system": {"type": "text", "fields": {"keyword": {"type": "keyword", "ignore_above": 256}}}
