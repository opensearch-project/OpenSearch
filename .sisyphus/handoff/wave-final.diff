package org.opensearch.index.engine.dataformat;

import org.opensearch.common.annotation.ExperimentalApi;

import java.io.IOException;

/**
 * Thrown when a reader cannot interpret a file or catalog produced at a newer or incompatible
 * format version.
 */
@ExperimentalApi
public class UnreadableFormatVersionException extends IOException {

    /**
     * Constructs an exception for a specific file that cannot be read.
     *
     * @param formatName    the data format name (e.g., "parquet")
     * @param fileName      the file that cannot be read
     * @param producedAt    the format version the file was produced at
     * @param readerCurrent the current reader's format version
     */
    public UnreadableFormatVersionException(String formatName, String fileName, String producedAt, String readerCurrent) {
        super(
            "Cannot read format ["
                + formatName
                + "] file ["
                + fileName
                + "] produced at version ["
                + producedAt
                + "]; reader current version ["
                + readerCurrent
                + "]"
        );
    }

    /**
     * Constructs an exception for a catalog-level version incompatibility.
     *
     * @param formatName    the data format name
     * @param producedAt    the format version the data was produced at
     * @param readerCurrent the current reader's format version
     */
    public UnreadableFormatVersionException(String formatName, String producedAt, String readerCurrent) {
        super(
            "Cannot read format ["
                + formatName
                + "] produced at version ["
                + producedAt
                + "]; reader current version ["
                + readerCurrent
                + "]"
        );
    }
}


