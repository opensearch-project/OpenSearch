package org.opensearch.parquet;

import org.opensearch.index.engine.dataformat.DataFormatDescriptor;
import org.opensearch.test.OpenSearchTestCase;

import java.util.Map;
import java.util.function.Supplier;

public class ParquetDataFormatPluginTests extends OpenSearchTestCase {

    private DataFormatDescriptor descriptor() {
        ParquetDataFormatPlugin plugin = new ParquetDataFormatPlugin();
        Map<String, Supplier<DataFormatDescriptor>> descriptors = plugin.getFormatDescriptors(null, null);
        return descriptors.get("parquet").get();
    }

    public void testCanReadNull() {
        assertTrue(descriptor().canRead(null));
    }

    public void testCanReadEmpty() {
        assertTrue(descriptor().canRead(""));
    }

    public void testCanReadSameMajor() {
        assertTrue(descriptor().canRead("1.0.0.0"));
        assertTrue(descriptor().canRead("1.9.9.9"));
    }

    public void testCanReadDifferentMajor() {
        assertFalse(descriptor().canRead("2.0.0.0"));
    }

    public void testCanReadGarbage() {
        assertFalse(descriptor().canRead("not-a-version"));
    }

    public void testCurrentVersion() {
        assertEquals("1.0.0.0", descriptor().currentVersion());
    }
}


