import org.opensearch.index.engine.exec.Segment;
import org.opensearch.index.engine.exec.WriterFileSet;
import org.opensearch.index.store.PrecomputedChecksumStrategy;
import org.opensearch.test.OpenSearchTestCase;

import java.util.List;
import java.util.Set;
import java.util.function.Function;

public class DataFormatAwareNRTReplicationEngineValidationTests extends OpenSearchTestCase {

    private static final String PARQUET = "parquet";

    private MockCatalogSnapshot snapshotWith(String formatName, String formatVersion) {
        WriterFileSet wfs = new WriterFileSet("/tmp", 1L, Set.of("file.parquet"), 100, formatVersion);
        Segment segment = Segment.builder(1L).addSearchableFiles(formatName, wfs).build();
        return new MockCatalogSnapshot(1L, List.of(segment), new MockDataFormat(formatName, 100L, Set.of()));
    }

    private DataFormatDescriptor descriptorThatCanRead(boolean canRead, String currentVersion) {
        return new DataFormatDescriptor(PARQUET, new PrecomputedChecksumStrategy()) {
            @Override
            public String currentVersion() {
                return currentVersion;
            }

            @Override
            public boolean canRead(String producedAt) {
                return canRead;
            }
        };
    }

    public void testEmptyCatalogPasses() throws Exception {
        MockCatalogSnapshot empty = new MockCatalogSnapshot(1L, List.of(), new MockDataFormat());
        DataFormatVersionValidator.validate(empty, name -> null);
        // no exception = pass
    }

    public void testValidFormatPasses() throws Exception {
        MockCatalogSnapshot snapshot = snapshotWith(PARQUET, "1.0.0.0");
        Function<String, DataFormatDescriptor> lookup = name -> descriptorThatCanRead(true, "1.0.0.0");
        DataFormatVersionValidator.validate(snapshot, lookup);
    }

    public void testMissingPluginThrows() {
        MockCatalogSnapshot snapshot = snapshotWith(PARQUET, "1.0.0.0");
        UnreadableFormatVersionException ex = expectThrows(
            UnreadableFormatVersionException.class,
            () -> DataFormatVersionValidator.validate(snapshot, name -> null)
        );
        assertTrue(ex.getMessage().contains("plugin not installed"));
    }

    public void testCanReadFalseThrows() {
        MockCatalogSnapshot snapshot = snapshotWith(PARQUET, "2.0.0.0");
        Function<String, DataFormatDescriptor> lookup = name -> descriptorThatCanRead(false, "1.0.0.0");
        UnreadableFormatVersionException ex = expectThrows(
            UnreadableFormatVersionException.class,
            () -> DataFormatVersionValidator.validate(snapshot, lookup)
        );
        assertTrue(ex.getMessage().contains("2.0.0.0"));
    }

    public void testEmptyFormatVersionBwc() throws Exception {
        MockCatalogSnapshot snapshot = snapshotWith(PARQUET, "");
        // Default descriptor accepts everything including empty
        DataFormatDescriptor defaultDescriptor = new DataFormatDescriptor(PARQUET, new PrecomputedChecksumStrategy());
        DataFormatVersionValidator.validate(snapshot, name -> defaultDescriptor);
    }

    public void testLuceneFormatSkipped() throws Exception {
        WriterFileSet wfs = new WriterFileSet("/tmp", 1L, Set.of("_0.cfs"), 100, "10.4.0");
        Segment segment = Segment.builder(1L).addSearchableFiles("lucene", wfs).build();
        MockCatalogSnapshot snapshot = new MockCatalogSnapshot(1L, List.of(segment), new MockDataFormat("lucene", 0, Set.of()));
        // null lookup — would throw if lucene wasn't skipped
        DataFormatVersionValidator.validate(snapshot, name -> null);
    }
}


