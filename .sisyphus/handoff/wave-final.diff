package org.opensearch.index.engine.dataformat;

import org.opensearch.index.store.PrecomputedChecksumStrategy;
import org.opensearch.test.OpenSearchTestCase;

public class DataFormatDescriptorTests extends OpenSearchTestCase {

    private DataFormatDescriptor defaultDescriptor() {
        return new DataFormatDescriptor("test-format", new PrecomputedChecksumStrategy());
    }

    public void testDefaultCurrentVersionIsEmpty() {
        assertEquals("", defaultDescriptor().currentVersion());
    }

    public void testDefaultCanReadNullTrue() {
        assertTrue(defaultDescriptor().canRead(null));
    }

    public void testDefaultCanReadEmptyTrue() {
        assertTrue(defaultDescriptor().canRead(""));
    }

    public void testDefaultCanReadAnyTrue() {
        assertTrue(defaultDescriptor().canRead("99.99.99"));
    }

    public void testOverrideChangesBehavior() {
        DataFormatDescriptor custom = new DataFormatDescriptor("custom", new PrecomputedChecksumStrategy()) {
            @Override
            public String currentVersion() {
                return "2.0.0";
            }

            @Override
            public boolean canRead(String producedAt) {
                return "2.0.0".equals(producedAt);
            }
        };
        assertEquals("2.0.0", custom.currentVersion());
        assertTrue(custom.canRead("2.0.0"));
        assertFalse(custom.canRead("1.0.0"));
    }
}


