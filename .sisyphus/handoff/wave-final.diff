package org.opensearch.index.engine;

import org.opensearch.index.engine.dataformat.DataFormatDescriptor;
import org.opensearch.index.engine.dataformat.UnreadableFormatVersionException;
import org.opensearch.index.engine.exec.Segment;
import org.opensearch.index.engine.exec.WriterFileSet;
import org.opensearch.index.engine.exec.coord.CatalogSnapshot;

import java.util.Map;
import java.util.function.Function;

/**
 * Validates that all non-Lucene format versions in a catalog snapshot are readable
 * by the installed plugins. Extracted from DataFormatAwareNRTReplicationEngine for testability.
 */
final class DataFormatVersionValidator {

    private DataFormatVersionValidator() {}

    /**
     * Validates format versions in the given snapshot against the descriptor lookup.
     *
     * @param snapshot              the catalog snapshot to validate
     * @param descriptorByFormatName function to look up a descriptor by format name
     * @throws UnreadableFormatVersionException if a format is missing or cannot read the version
     */
    static void validate(CatalogSnapshot snapshot, Function<String, DataFormatDescriptor> descriptorByFormatName)
        throws UnreadableFormatVersionException {
        for (Segment segment : snapshot.getSegments()) {
            for (Map.Entry<String, WriterFileSet> entry : segment.dfGroupedSearchableFiles().entrySet()) {
                String formatName = entry.getKey();
                if ("lucene".equals(formatName)) {
                    continue;
                }
                WriterFileSet wfs = entry.getValue();
                DataFormatDescriptor descriptor = descriptorByFormatName.apply(formatName);
                if (descriptor == null) {
                    throw new UnreadableFormatVersionException(formatName, wfs.formatVersion(), "<plugin not installed>");
                }
                if (!descriptor.canRead(wfs.formatVersion())) {
                    throw new UnreadableFormatVersionException(formatName, wfs.formatVersion(), descriptor.currentVersion());
                }
            }
        }
    }
}


