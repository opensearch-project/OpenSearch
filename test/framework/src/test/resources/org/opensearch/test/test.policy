grant codeBase "${codebase.opensearch-nio}" {
  permission java.net.NetPermission "accessUnixDomainSocket";
  permission java.net.SocketPermission "*", "accept,connect,listen,resolve";
};


grant codeBase "${codebase.framework}" {
  permission java.net.NetPermission "accessUnixDomainSocket";
  permission java.net.SocketPermission "*", "accept,connect,listen,resolve";
};


grant {
    // Allow socket connections for Netty transport tests
    permission java.net.NetPermission "accessUnixDomainSocket";
    permission java.net.SocketPermission "localhost:0", "listen,resolve,accept,connect";
    permission java.net.SocketPermission "127.0.0.1:0", "listen,resolve,accept,connect";
    permission java.net.SocketPermission "*", "connect,resolve,listen,accept";
};